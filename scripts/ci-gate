#!/usr/bin/env bash
#
# scripts/ci-gate — cargoless's DEDICATED build/test gate.
#
# WHY THIS EXISTS
#   cargoless's .forgejo CI runs on a single serial Forgejo Actions runner
#   that is shared with tf-multiverse + ~12 agents (often ~40min backlogged)
#   and whose job logs are NOT readable over the Forgejo REST API. That makes
#   it useless as a fast pre-integration merge gate. This script runs the
#   exact same checks on a dedicated, isolated k8s pod and prints the real
#   per-check PASS/FAIL **and the actual compiler/test output to stdout** —
#   kubectl-exec stdout IS readable, which is the whole point.
#
#   The builder is fully independent of tf-multiverse's `triform-builder`
#   namespace and of the Forgejo runner. See deploy/cargoless-builder.k8s.yaml.
#
# OPERATOR AUTHORISATION
#   The human operator explicitly authorised cargoless having its own builder
#   and using kubectl + remote cargo for it. Every remote cargo/rustc/rustup
#   invocation is therefore prefixed `TRIFORM_OPERATOR_APPROVED_BUILD=1` —
#   the cargo-safety hook's sanctioned escape for operator-approved builds.
#
# USAGE
#   scripts/ci-gate [<git-ref>]      # 4-check merge gate (default ref origin/main)
#   scripts/ci-gate <ref> --update-lock
#                                    # OPT-IN: run `cargo update --workspace`
#                                    #   IN-POD on the freshly-streamed source,
#                                    #   capture regenerated Cargo.lock back to
#                                    #   the host gated-tree root, THEN run the
#                                    #   7-phase gate (which proves the new
#                                    #   lock builds/tests/lints green BEFORE
#                                    #   you commit it). Default invocations
#                                    #   are byte-identical to pre-#266.
#                                    #   Alt env form: CI_GATE_UPDATE_LOCK=1
#   scripts/ci-gate --bench <ref>    # run the S1/AC#2 bench harness for <ref>
#                                    #   and publish the `s1-ac2-verdict`
#                                    #   Forgejo commit status for that sha
#   scripts/ci-gate --provision      # (re)apply the builder manifest, then exit
#   scripts/ci-gate --help
#
#   The ref must exist in your LOCAL clone (this script never pull/fetches —
#   agents don't, and the lead already has the branches). The working tree at
#   that ref is `git archive`-streamed into the pod over `kubectl exec` stdin
#   (no in-pod git, no registry auth, deterministic — tracked files only).
#
#   The gate runs the four .forgejo checks under DEFAULT features, then —
#   iff crates/cargoless/Cargo.toml declares an `integration` feature in the
#   streamed tree — ALSO runs build/test/clippy for `-p cargoless --features
#   integration` (the wired daemon, excluded from the default build). On a
#   tree with no such feature those three are reported SKIPPED, not failed.
#
#   --bench exists because the CI `bench` job (which publishes the
#   `s1-ac2-verdict` commit status gating the project's #1 risk, D-A2/AC#2)
#   is `if: github.ref == refs/heads/main` AND sits behind the ~40min shared
#   runner. This runs bench/run.sh in the dedicated pod NOW and POSTs the
#   verdict as the commit status from the local machine (Forgejo token read
#   via the documented `git credential fill` path — never placed in the pod).
#   bench/run.sh always exits 0 by contract (evidence, not a gate), so
#   --bench's exit code reflects only transport success, not the verdict.
#
# ENV
#   BUILDER_NS    default cargoless-builder
#   BUILDER_SEL   default app.kubernetes.io/name=cargoless-builder
#   CI_GATE_KEEP_GOING=1  run all four checks even after one fails (default:
#                         keep going — a gate should report every failure)
#   CI_GATE_UPDATE_LOCK=1 opt-in: regenerate Cargo.lock in-pod before the
#                         7-phase gate (equivalent to --update-lock flag)
#   FJ_API        default https://forgejo.triform.dev/api/v1
#   FJ_REPO       default triform/cargoless
#
# EXIT: gate mode  → 0 iff all four checks pass; 1 if any red; 2 on setup err.
#       --bench    → 0 if the verdict was captured + status POSTed; 2 on error.
#       --update-lock additionally → 2 if `cargo update` itself fails (the
#                    gate ABORTS BEFORE the 7 phases run — no silent
#                    fall-through to "gating with old lock while claiming
#                    fresh"; §9a-trap defense; host Cargo.lock UNCHANGED).

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUILDER_NS="${BUILDER_NS:-cargoless-builder}"
BUILDER_SEL="${BUILDER_SEL:-app.kubernetes.io/name=cargoless-builder}"
BUILDER_CONTAINER="builder"
MANIFEST="$REPO_ROOT/deploy/cargoless-builder.k8s.yaml"
CI_GATE_KEEP_GOING="${CI_GATE_KEEP_GOING:-1}"
APPROVE="TRIFORM_OPERATOR_APPROVED_BUILD=1"   # operator-sanctioned build escape

# ── Per-ref CARGO_TARGET_DIR — verdict-integrity invariant (STOP-class) ──────
# deploy/cargoless-builder.k8s.yaml pins pod env CARGO_TARGET_DIR=/cache/target
# (ONE PVC dir, EVERY branch, every concurrent gate). cargo's fingerprint does
# NOT encode git-ref identity, so two different branches building into that one
# dir can alias: a `cargo test` phase can re-run a FOREIGN branch's compiled
# test binary (evidenced: a #7 gate on base 4687e3c — no config.rs — ran 10
# `config::tests::` from a concurrent #1 branch). A green-mechanism that can
# execute another branch's tests is launch-blocking — the product's whole
# claim is "the codebase knows what's green".
#
# Structural fix (not flock-serialize, which only orders the aliasing): give
# each gated commit its OWN target dir, keyed by the resolved full SHA. A git
# SHA is content-addressed, so $CI_TARGET_ROOT/<SHA> is only ever written from
# THAT commit's identical source — the test binaries in it provably belong to
# the gated ref and nothing else (own-branch provenance becomes a filesystem
# invariant, not a hope). Same-SHA re-gates still reuse the dir (preserves the
# diagnosed-same-SHA-re-gate / 2×-reconfirm speed); different SHAs are
# physically isolated; cargo's own target lock handles same-SHA concurrency.
# The #81 mtime-bump stays — it keeps a same-SHA re-gate fresh vs that SHA's
# own cached artifacts and is defense-in-depth.
CI_TARGET_ROOT="${CI_GATE_TARGET_ROOT:-/cache/ci-targets}"
CTARGET=""   # set once $SHA is resolved (below); injected into every pod cargo
FJ_API="${FJ_API:-https://forgejo.triform.dev/api/v1}"
FJ_REPO="${FJ_REPO:-triform/cargoless}"

# ── Per-ref SOURCE dir — verdict-integrity invariant, part 2 (STOP-class) ────
# Per-ref CARGO_TARGET_DIR (above) isolates the *target* dir but NOT the
# source: the old fixed `REMOTE_SRC=/work/src` is `rm -rf`'d + re-extracted
# by every gate, and the cargoless-builder pod is SHARED across the fleet
# (multiple agents) AND a single agent may run concurrent gates. Two
# concurrent invocations RACE on one /work/src: gate A extracts SHA-A, gate
# B `rm -rf`s + extracts SHA-B, gate A's cargo then compiles SHA-B's source
# into A's (correctly-isolated) target dir → verdict labelled SHA-A, built
# from SHA-B's source. Evidenced: two concurrently-launched re-vals of
# distinct SHAs produced byte-identical test sets. The per-ref-target fix
# could not catch this — the SOURCE itself was swapped.
#
# Completion of the same structural pattern: the source dir is ALSO keyed
# to the content-addressed SHA ($REMOTE_SRC_ROOT/<SHA>). Source AND target
# are now both per-ref, so concurrent gates are fully independent; the only
# shared state left is the intended F-K heavy-lock + pod RAM + the
# content-addressed CARGO_HOME (cargo-safe). Own-ref provenance — source and
# compiled artifacts — is now a filesystem invariant end-to-end.
REMOTE_SRC_ROOT="${CI_GATE_SRC_ROOT:-/work/src.d}"
REMOTE_SRC=""   # set once $SHA is resolved (below): $REMOTE_SRC_ROOT/$SHA

usage() { sed -n '2,/^set -euo pipefail/p' "$0" | sed -e 's/^# \?//' -e '$d'; }
die() { echo "[ci-gate] ERROR: $*" >&2; exit 2; }

MODE="gate"

# ── #266: strip the composable --update-lock flag from positional args ──────
# The mode case below (`--provision`, `--bench`) is mutually exclusive — those
# are operational shapes, not modifiers. `--update-lock` is a MODIFIER on
# default gate mode (opt-in pre-gate lockfile regen), so it must be
# composable with the positional <ref> form and not collide with the case.
# Strip it FIRST (any position), then let the case + REF resolution run as
# before with byte-identical semantics on a non-update-lock invocation. The
# env-var alternative CI_GATE_UPDATE_LOCK=1 is the default initializer.
UPDATE_LOCK="${CI_GATE_UPDATE_LOCK:-0}"
__nargs=()
for __a in "$@"; do
  case "$__a" in
    --update-lock) UPDATE_LOCK=1 ;;
    *) __nargs+=("$__a") ;;
  esac
done
# Safe under `set -u` for empty arrays via the +alt-value idiom:
set -- ${__nargs[@]+"${__nargs[@]}"}
unset __nargs __a

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  --provision)
    command -v kubectl >/dev/null || die "kubectl not found"
    [ -f "$MANIFEST" ] || die "manifest missing: $MANIFEST"
    echo "[ci-gate] applying $MANIFEST"
    kubectl apply -f "$MANIFEST"
    kubectl -n "$BUILDER_NS" rollout status deploy/cargoless-builder --timeout=240s
    echo "[ci-gate] builder provisioned."
    exit 0 ;;
  --bench) MODE="bench"; shift ;;
esac

# --update-lock is a modifier on default gate mode only. Combining it with
# --bench would be silently ignored (the bench path exits before the gate
# block runs), so refuse LOUD instead — honesty > silent-discard.
if [ "$UPDATE_LOCK" = "1" ] && [ "$MODE" = "bench" ]; then
  die "--update-lock is for default gate mode only (cannot combine with --bench)"
fi

REF="${1:-origin/main}"
command -v kubectl >/dev/null || die "kubectl not found"
command -v git >/dev/null || die "git not found"

SHA="$(git -C "$REPO_ROOT" rev-parse --verify "${REF}^{commit}" 2>/dev/null)" \
  || die "ref '$REF' not found in local clone. Pass a local branch or a ref the lead already has."
SHORT="$(git -C "$REPO_ROOT" rev-parse --short "$SHA")"

# Per-ref isolated target dir (see CI_TARGET_ROOT block above). Keyed by the
# full content-addressed SHA so the dir's compiled artifacts provably belong
# to THIS ref only. Injected as an env-assignment prefix on every in-pod
# cargo (overrides the pod's pinned CARGO_TARGET_DIR=/cache/target).
CTARGET="CARGO_TARGET_DIR=$CI_TARGET_ROOT/$SHA"
# Per-ref source dir (see REMOTE_SRC_ROOT block above) — keyed to the same
# content-addressed SHA so concurrent gates never race a shared /work/src.
REMOTE_SRC="$REMOTE_SRC_ROOT/$SHA"

# ── D1 brand-completion enforced invariant (#96) — fast local pre-flight ─────
# Greps the gated ref's tree for banned old-brand tokens (see
# scripts/d1-drift-guard TOKEN_RE for the precise regex) in the brand-
# load-bearing surface (crates/ scripts/ .github/ .forgejo/ deploy/) and
# asserts every hit is on the committed scripts/.d1-drift-allowlist.
# Runs LOCALLY in the invoking shell (no kubectl/pod work) so a brand-
# residual fails FAST without burning a full pod build. Soft-skips when
# the guard is absent (gracefully degrades on pre-#96 historical commits
# — keeps re-gating old SHAs viable). See scripts/d1-drift-guard for
# the full scope/rationale.
if [ -x "$REPO_ROOT/scripts/d1-drift-guard" ]; then
  echo
  echo "======================================================================"
  echo "=== d1-drift :: scripts/d1-drift-guard $SHORT  [local pre-flight; no pod]"
  echo "======================================================================"
  if "$REPO_ROOT/scripts/d1-drift-guard" "$SHA"; then
    echo "--- d1-drift: PASS"
  else
    echo "--- d1-drift: FAIL (D1 brand-residual outside allowlist — see violations above)"
    echo
    echo "======================================================================"
    echo "=== ci-gate verdict   ref=$REF  sha=$SHORT  (d1-drift pre-flight FAILED)"
    echo "======================================================================"
    printf '  %-12s %s\n' "d1-drift" "FAIL"
    echo "  (build/test/fmt/clippy/integ-* SKIPPED — pre-flight failed; pod work not started)"
    echo "=== RESULT: RED — do NOT integrate $SHORT"
    echo "    fix the residual OR add a justified scripts/.d1-drift-allowlist entry"
    exit 1
  fi
fi

POD="$(kubectl -n "$BUILDER_NS" get pod -l "$BUILDER_SEL" \
  --field-selector=status.phase=Running \
  -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)"
[ -n "$POD" ] || die "no Running cargoless builder pod (try: scripts/ci-gate --provision)"

kexec()  { kubectl exec      -n "$BUILDER_NS" "$POD" -c "$BUILDER_CONTAINER" -- "$@"; }
kexec_i() { kubectl exec -i   -n "$BUILDER_NS" "$POD" -c "$BUILDER_CONTAINER" -- "$@"; }

# ── #263 (3): pre-flight /cache PVC space check ──────────────────────────────
# An exhausted /cache PVC fails cargo mid-build with confusing exit codes
# (often 137-class OOM-looking — actually ENOSPC from a write deep inside a
# linker invocation) instead of a clear "out of space" message. Pre-flight
# queries available KB on /cache + aborts LOUDLY with the exact reclaim
# command an operator can copy-paste — the diagnostic IS the fix.
#
# Threshold default 5GiB (configurable via CI_GATE_PREFLIGHT_MIN_KB) is
# empirical for the cargoless ci-gate's 7-phase cycle: a cold cargo build's
# deps + final-link peaks around 2-3GB; integ-* roughly doubles target-dir
# size; warm-cache hits + active /work/src.d add ~5GB pre-existing. 5GiB
# headroom safely covers a full cycle on a typical pod-state.
#
# Fail-soft on df-query failure: if the df invocation itself errors (e.g.,
# busybox image without `--output=avail` support), AVAIL_KB is empty + the
# bounds-check short-circuits without aborting. The pre-flight is a safety
# NET, not a gatekeeper — false-negative (let through) is safer than
# false-positive (block valid gate). Motivated by dev-fixer's autonomous
# +12G /cache reclaim event (post-#240/2c integration cycle).
PREFLIGHT_THRESHOLD_KB="${CI_GATE_PREFLIGHT_MIN_KB:-$((5 * 1024 * 1024))}"
AVAIL_KB="$(kexec df --output=avail /cache 2>/dev/null | tail -1 | tr -d ' ')"
if [ -n "$AVAIL_KB" ] && [ "$AVAIL_KB" -lt "$PREFLIGHT_THRESHOLD_KB" ] 2>/dev/null; then
  AVAIL_GB=$((AVAIL_KB / 1024 / 1024))
  THRESHOLD_GB=$((PREFLIGHT_THRESHOLD_KB / 1024 / 1024))
  echo "[ci-gate] ERROR: /cache PVC has only ${AVAIL_GB}GiB free; gate needs >=${THRESHOLD_GB}GiB" >&2
  echo "[ci-gate] reclaim: kubectl exec -n $BUILDER_NS $POD -c $BUILDER_CONTAINER -- \\" >&2
  echo "[ci-gate]   bash -c 'find $CI_TARGET_ROOT $REMOTE_SRC_ROOT -mindepth 1 -maxdepth 1 -type d -mmin +60 -exec rm -rf {} +'" >&2
  echo "[ci-gate] (the same housekeeping stream_tree runs at every gate; this just applies it NOW outside the gate flow)" >&2
  exit 2
fi

# Fresh source dir per run; the per-ref CARGO_TARGET_DIR
# ($CI_TARGET_ROOT/$SHA) lives OUTSIDE this dir on the PVC so a same-SHA
# re-gate reuses that ref's own warm cache (relink, not from-scratch) while
# different SHAs stay physically isolated (verdict-integrity invariant).
# git archive => tracked files only.
stream_tree() {
  echo "[ci-gate] ref=$REF sha=$SHORT pod=$BUILDER_NS/$POD"
  echo "[ci-gate] per-ref source dir: $REMOTE_SRC (isolated; concurrent gates cannot race it)"
  echo "[ci-gate] per-ref target dir: $CI_TARGET_ROOT/$SHA (isolated; pod's /cache/target NOT used)"
  echo "[ci-gate] streaming tree into pod (git archive | kubectl exec tar -x)..."
  kexec bash -c "rm -rf $REMOTE_SRC && mkdir -p $REMOTE_SRC && mkdir -p $CI_TARGET_ROOT/$SHA" \
    || die "could not reset $REMOTE_SRC / create per-ref target dir in pod"
  # Bound PVC growth: best-effort prune sibling per-ref SOURCE + TARGET dirs
  # untouched for >60min (#263 tighten from the original 24h threshold).
  # Rationale: a gate runs in minutes; >60min ⇒ provably not an in-flight
  # concurrent gate's dir, so removing it cannot false-red a live run. The
  # 24h threshold let stale per-ref dirs accumulate faster than they aged
  # out at fleet cadence (motivated by dev-fixer's autonomous +12G /cache
  # reclaim post-#240/2c). Tightening to 60min keeps same-cycle re-gates
  # warm-cache-eligible while aggressively reclaiming yesterday's dirs that
  # the 24h threshold would have kept. Never touches THIS $SHA's dirs.
  # Failure here never fails the gate (|| true) — a housekeeping miss must
  # not block a verdict. Pairs with the gate-entry pre-flight space-check
  # above as defense-in-depth (preflight catches what housekeeping missed).
  kexec bash -c "find $CI_TARGET_ROOT $REMOTE_SRC_ROOT -mindepth 1 -maxdepth 1 -type d ! -name $SHA -mmin +60 -exec rm -rf {} + 2>/dev/null || true" || true
  git -C "$REPO_ROOT" archive --format=tar "$SHA" \
    | kexec_i tar -x -C "$REMOTE_SRC" \
    || die "source transfer failed"
  # Defeat the git-archive-mtime + PVC-cache stale-green trap:
  # `git archive` writes extracted files with mtime = commit timestamp.
  # The PVC-resident CARGO_TARGET_DIR persists across runs, and its cached
  # build artifacts have mtime = LAST-RUN-time (usually NEWER than any
  # commit). cargo's mtime-based fingerprint then sees
  # `target/.../deps/foo.rlib > src/foo.rs` and SKIPS the rebuild — the
  # cached binary (without the new code's tests/changes) runs and the gate
  # reports green for OLD code. This silent-stale-green nearly shipped
  # F8-redo's dangling identifier (d16b695) AND F12's substring-matching
  # bug — both caught only by dev-fixer pushing a second commit which had
  # a newer timestamp and force-busted the cache.
  #
  # Fix: bump every extracted file's mtime to NOW. cargo then sees source
  # NEWER than cached artifact and rebuilds correctly. Costs ~1s; cheaper
  # than `cargo clean -p <crate>` (which would force a 30-60s rebuild even
  # when sources legitimately match the cache). See dev-fixer's diagnostic
  # in agent/dev-fixer-5 / lead's routing message Item 3 (2026-05-17).
  echo "[ci-gate] bumping mtimes (defeats git-archive-mtime / PVC-cache stale-green trap)..."
  kexec bash -c "find $REMOTE_SRC -type f -exec touch {} +" \
    || die "mtime bump failed"
}

# ───────────────────────── --bench: S1/AC#2 verdict ─────────────────────────
if [ "$MODE" = "bench" ]; then
  stream_tree
  echo
  echo "======================================================================"
  echo "=== bench :: bench/run.sh (S1 / AC#2 latency harness)  sha=$SHORT"
  echo "======================================================================"
  set +e
  BENCH_OUT="$(kexec_i bash -c \
    "cd $REMOTE_SRC && $APPROVE $CTARGET bash bench/run.sh 2>&1")"
  set -e
  printf '%s\n' "$BENCH_OUT"
  VERDICT="$(printf '%s\n' "$BENCH_OUT" | grep -m1 '^S1_VERDICT:' || true)"
  [ -n "$VERDICT" ] || VERDICT="S1_VERDICT: BLOCKER=no-verdict-line AC2=UNKNOWN D-A2=BLOCKED"
  echo
  echo "[ci-gate] captured: $VERDICT"

  # Forgejo token via the documented read path (macOS keychain credential).
  # Never written into the pod — the status is POSTed from here.
  TOKEN="$(printf 'protocol=https\nhost=forgejo.triform.dev\n\n' \
    | git credential fill 2>/dev/null | sed -n 's/^password=//p')"
  [ -n "$TOKEN" ] || die "could not read Forgejo token via git credential fill"

  DESC="$(printf '%s' "$VERDICT" | cut -c1-255)"
  BODY="$(python3 -c 'import json,sys; print(json.dumps({"state":"success","context":"s1-ac2-verdict","description":sys.argv[1]}))' "$DESC")"
  CODE="$(curl -sS -o /tmp/ci-gate-s1resp.json -w '%{http_code}' \
    -X POST -H "Authorization: token ${TOKEN}" -H "Content-Type: application/json" \
    "${FJ_API}/repos/${FJ_REPO}/statuses/${SHA}" -d "$BODY" || true)"
  echo "[ci-gate] POST ${FJ_API}/repos/${FJ_REPO}/statuses/${SHA} -> HTTP ${CODE}"
  case "$CODE" in
    2??) echo "=== bench: verdict published as commit status 's1-ac2-verdict' for $SHORT"; exit 0 ;;
    *)   echo "=== bench: STATUS POST FAILED (HTTP $CODE)"; head -c 400 /tmp/ci-gate-s1resp.json 2>/dev/null; echo; exit 2 ;;
  esac
fi

# ───────────────────────── default: 4-check merge gate ──────────────────────
stream_tree

# ── #266: opt-in pre-gate lockfile regen ────────────────────────────────────
# The gate pins `--locked` on every cargo invocation (matches .forgejo/ci.yml
# post-#25): drift between Cargo.toml and Cargo.lock fails LOUD as gate-red.
# That's the right discipline for integration runs but leaves agents with no
# in-band way to refresh the lockfile — the cargo-safety hook blocks local
# `cargo update` and there's no committed escape for it. This opt-in mode
# fills that gap:
#
#   1) Run `cargo update --workspace` IN THE POD on the freshly-streamed
#      per-ref source tree (the same $REMOTE_SRC the 7 phases will use).
#   2) If regen FAILS — abort the gate LOUD. Do NOT fall through into the
#      7 phases (that would gate the OLD lock while the operator believes
#      they're gating the new one — silent-stale-green class, §9a-trap).
#      The host Cargo.lock is left UNCHANGED.
#   3) If regen SUCCEEDS — capture the regenerated $REMOTE_SRC/Cargo.lock
#      back to $REPO_ROOT/Cargo.lock on the host (the gated-tree root, so
#      a follow-up `git add Cargo.lock && git commit` applies it). Surface
#      the diff up to the first 200 lines so the operator can eyeball what
#      moved before committing. The 7 phases below run on the in-pod tree
#      which has the new lock — their --locked greens ARE the proof that
#      the refreshed lockfile builds/tests/lints cleanly.
#
# §9a-trap defense surface: cargo update failure ⇒ exit "$URC" BEFORE the
# 4-check loop. The original host Cargo.lock is mutated only AFTER
# verifying the in-pod capture is non-empty (truncated transport ≠ valid
# lock). Default invocations (no --update-lock + no CI_GATE_UPDATE_LOCK=1)
# skip this block entirely — UPDATE_LOCK=0 short-circuits the `if`.
if [ "$UPDATE_LOCK" = "1" ]; then
  echo
  echo "======================================================================"
  echo "=== update-lock :: cargo update --workspace  sha=$SHORT  [in-pod regen]"
  echo "======================================================================"
  set +e
  UPDATE_OUT="$(kexec_i bash -c \
    "cd $REMOTE_SRC && $APPROVE $CTARGET cargo update --workspace 2>&1")"
  URC=$?
  set -e
  printf '%s\n' "$UPDATE_OUT"
  if [ "$URC" -ne 0 ]; then
    echo "--- update-lock: FAIL (exit $URC)"
    echo
    echo "======================================================================"
    echo "=== ci-gate verdict   ref=$REF  sha=$SHORT  (update-lock FAILED — gate ABORTED)"
    echo "======================================================================"
    echo "  cargo update --workspace failed; refusing to run 7-phase gate on"
    echo "  the unmodified lock while claiming a fresh regen happened."
    echo "  host Cargo.lock UNCHANGED; fix the regen failure + retry."
    echo "=== RESULT: ABORTED — $SHORT not gated (update-lock pre-step red)"
    exit "$URC"
  fi
  echo "--- update-lock: regen complete (exit 0); capturing Cargo.lock to host"
  # Atomic capture: cat to tempfile, verify non-empty, diff vs host, then
  # cp into place. A truncated kubectl-exec pipe must not partial-replace
  # the host lock (mid-write corruption would defeat the §9a-trap defense).
  TMP_LOCK="$(mktemp)"
  # Best-effort tempfile cleanup; do NOT clobber an existing EXIT trap if
  # one is set later in the script's lifetime — currently none, so direct
  # assignment is safe.
  trap 'rm -f "$TMP_LOCK"' EXIT
  if ! kexec cat "$REMOTE_SRC/Cargo.lock" > "$TMP_LOCK"; then
    die "could not capture regenerated Cargo.lock from $REMOTE_SRC/Cargo.lock (transport failed)"
  fi
  if [ ! -s "$TMP_LOCK" ]; then
    die "captured Cargo.lock is empty — transport truncated; host Cargo.lock UNCHANGED"
  fi
  if cmp -s "$TMP_LOCK" "$REPO_ROOT/Cargo.lock" 2>/dev/null; then
    echo "[update-lock] host Cargo.lock is byte-identical to regenerated copy (no-op write skipped)"
  else
    echo "[update-lock] diff (host → regenerated, first 200 lines of unified diff):"
    diff -u "$REPO_ROOT/Cargo.lock" "$TMP_LOCK" 2>/dev/null | head -200 || true
    echo "[update-lock] (full regenerated lock follows the gate; capturing now)"
    cp "$TMP_LOCK" "$REPO_ROOT/Cargo.lock"
    echo "[update-lock] host Cargo.lock REPLACED ($REPO_ROOT/Cargo.lock)"
    echo "[update-lock] follow-up: review the diff, then 'git add Cargo.lock && git commit' on top of $SHORT"
  fi
  echo "[update-lock] proceeding to 7-phase gate on in-pod tree (now carries the regenerated lock)"
fi

# Each check: prefixed with the operator-approved build escape, run in the
# streamed tree, full output captured and echoed. rust-toolchain.toml pins
# 1.85.0 (warm on the PVC) so the toolchain matches CI exactly.
# D-CI-RESILIENCE F-K (split, lead-routed 2026-05-18): the cargoless-builder
# pod is SHARED across the agent fleet; ci-gate runs its own checks serially
# but multiple agents' ci-gate invocations hit the SAME pod concurrently —
# N parallel heavy `cargo` builds in one pod → memory oversubscription →
# SIGKILL `exit 137` (#122-gate1) / FS-stream races (#123-step4). The
# *root-cause* cheap fix lands HERE: a pod-local flock so the two
# high-memory integ steps (integ-build, integ-test) are MUTUALLY EXCLUSIVE
# across all concurrent ci-gate invocations on this pod — they queue
# instead of OOMing. Self-validating (this very gate exercises it).
#   - DEFERRED to v0.1 (lead-routed): bumping the cargoless-builder
#     Deployment mem request/limit — prod gate-infra, non-self-validating,
#     higher blast radius; serialize-alone is expected to suffice.
#   - Interim if serialize is insufficient at any later gate: the
#     documented *diagnosed*-same-SHA-re-gate discipline (never blind) —
#     then STOP+surface to revisit the Deployment bump. See D-CI-RESILIENCE
#     §F-K + §2.1.
HEAVY_LOCK="${CI_GATE_HEAVY_LOCK:-/tmp/cargoless-cigate-heavy.lock}"
HEAVY_LOCK_WAIT="${CI_GATE_HEAVY_LOCK_WAIT:-2400}"   # 40m: > any single heavy step

run_check() {
  local name="$1" cmd="$2" serialize="${3:-0}" rc=0 out incmd tag=""
  # NB: `${serialize:+...}` would print for serialize="0" too ("0" is
  # set+non-empty) — the label must reflect ONLY the real flock'd steps.
  [ "$serialize" = "1" ] && tag="  [F-K serialized]"
  echo
  echo "======================================================================"
  echo "=== $name :: cargo ${cmd}${tag}"
  echo "======================================================================"
  if [ "$serialize" = "1" ]; then
    # Robust shell flock idiom: fd-redirection CREATES the lockfile (plain
    # `flock <file> cmd` errors if the file is absent); fd 9 holds the
    # exclusive lock for the cargo lifetime; -w timeout → rc 75 (distinct,
    # LOUD — a 40m wait is a real anomaly worth reding + diagnosing, never
    # silently masked).
    incmd="cd $REMOTE_SRC && ( flock -w $HEAVY_LOCK_WAIT 9 || { echo '::ci-gate:: F-K heavy-lock wait timeout (${HEAVY_LOCK_WAIT}s) — concurrent gate stuck?'; exit 75; }; $APPROVE $CTARGET cargo ${cmd} ) 9>$HEAVY_LOCK 2>&1"
  else
    incmd="cd $REMOTE_SRC && $APPROVE $CTARGET cargo ${cmd} 2>&1"
  fi
  set +e
  out="$(kexec_i bash -c "$incmd")"
  rc=$?
  set -e
  printf '%s\n' "$out"
  if [ "$rc" -eq 0 ]; then echo "--- $name: PASS"
  elif [ "$rc" -eq 75 ]; then echo "--- $name: FAIL (F-K heavy-lock timeout, exit 75 — diagnosed-re-gate, NOT a code defect)"
  else echo "--- $name: FAIL (exit $rc)"; fi
  return "$rc"
}

declare -A RESULT
OVERALL=0

# Mirrors .forgejo/workflows/ci.yml exactly: build, test, fmt, clippy.
# `--locked` matches ci.yml post-#25 (committed Cargo.lock; CI fails loud on
# lock drift instead of silently re-resolving). fmt resolves no deps so it
# omits --locked, exactly like ci.yml.
CHECKS=(
  "build|build --workspace --all-targets --locked"
  "test|test --workspace --locked"
  "fmt|fmt --all -- --check"
  "clippy|clippy --workspace --all-targets --locked -- -D warnings"
)

for entry in "${CHECKS[@]}"; do
  cname="${entry%%|*}"
  ccmd="${entry#*|}"
  if run_check "$cname" "$ccmd"; then
    RESULT[$cname]="PASS"
  else
    RESULT[$cname]="FAIL"
    OVERALL=1
    [ "$CI_GATE_KEEP_GOING" = "1" ] || break
  fi
done

# The `cargoless` published binary crate's wired daemon (check/serve/status
# against the live daemon-core + devserver) compiles ONLY under
# `--features integration`; the default workspace build deliberately excludes
# it (standalone holding-page semantics). The 4 checks above are
# default-feature only, so on the converged set they would NOT exercise the
# wired cargoless binary at all. (The crate lives at crates/cargoless/ — the
# directory path is unchanged by the D1 rename; only `[package] name`
# became `cargoless`.) Detect the
# feature in the STREAMED tree and, when present, gate it explicitly. This
# is a no-op on plain main (no `integration` feature → checks reported
# SKIPPED, not failed) and a hard gate on the convergence branch.
INTEG_CHECKS=(integ-build integ-test integ-clippy)
if kexec bash -c "grep -qE '^[[:space:]]*integration[[:space:]]*=' $REMOTE_SRC/crates/cargoless/Cargo.toml 2>/dev/null"; then
  echo
  echo "[ci-gate] cargoless (crates/cargoless/) declares an 'integration' feature — gating the wired daemon too"
  INTEG=(
    "integ-build|build -p cargoless --features integration --all-targets --locked"
    "integ-test|test -p cargoless --features integration --locked"
    "integ-clippy|clippy -p cargoless --features integration --all-targets --locked -- -D warnings"
  )
  for entry in "${INTEG[@]}"; do
    cname="${entry%%|*}"
    ccmd="${entry#*|}"
    # F-K: serialize the two high-memory integ steps (build, test) across
    # concurrent fleet ci-gate invocations on the shared pod; integ-clippy
    # reuses build artifacts and is light → left unserialized.
    case "$cname" in
      integ-build|integ-test) iser=1 ;;
      *)                      iser=0 ;;
    esac
    if run_check "$cname" "$ccmd" "$iser"; then
      RESULT[$cname]="PASS"
    else
      RESULT[$cname]="FAIL"
      OVERALL=1
      [ "$CI_GATE_KEEP_GOING" = "1" ] || break
    fi
  done
else
  echo
  echo "[ci-gate] no 'integration' feature in cargoless (crates/cargoless/) — wired-daemon checks SKIPPED (expected on plain main)"
fi

echo
echo "======================================================================"
echo "=== ci-gate verdict   ref=$REF  sha=$SHORT  pod=$BUILDER_NS/$POD"
echo "======================================================================"
for cname in build test fmt clippy "${INTEG_CHECKS[@]}"; do
  printf '  %-12s %s\n' "$cname" "${RESULT[$cname]:-SKIPPED}"
done
if [ "$OVERALL" -eq 0 ]; then
  echo "=== RESULT: ALL GREEN — safe to integrate $SHORT"
else
  echo "=== RESULT: RED — do NOT integrate $SHORT"
fi
exit "$OVERALL"
