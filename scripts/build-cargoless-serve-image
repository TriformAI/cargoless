#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VERSION="$(awk -F' = ' '/^version = / { gsub(/"/, "", $2); print $2; exit }' "$ROOT/Cargo.toml")"
IMAGE="${CARGOLESS_SERVE_IMAGE:-registry.triform.cloud/cargoless/cargoless-serve:${VERSION}}"
PLATFORM="${CARGOLESS_SERVE_PLATFORM:-linux/amd64}"

cd "$ROOT"
docker build --platform "$PLATFORM" -f deploy/cargoless-serve.Dockerfile -t "$IMAGE" .
docker push "$IMAGE"
