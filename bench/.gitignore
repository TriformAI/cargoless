# Standalone-workspace build outputs (these dirs are NOT covered by the
# repo-root /target rule).
fixture/target/
harness/target/
**/Cargo.lock.orig

# Comparative-bench artifact `--out` (cargoless `build --watch --out`
# materializes the latest-green dist here; trunk's --dist sibling lives
# under `fixture/dist/` (trunk default; cargoless's build orchestrator
# hardcodes project_root/dist so we use trunk's default everywhere).
fixture/.cargoless-bench-out/
fixture/trunk-dist/
# cargoless publisher pointer + CAS — written under the fixture root by
# `tftrunk build --watch` in artifact-mode benches; never source.
fixture/.cargoless/
